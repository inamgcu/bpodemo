{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BPO Yardi Reconciliation",
  "version": "0.1.0",
  "identifier": "com.bpo.yardireconciliation.clean",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "BPO Yardi Reconciliation",
        "width": 1440,
        "height": 920,
        "minWidth": 1160,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost data:; style-src 'self' 'unsafe-inline';"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "BPO Finance Operations",
    "copyright": "Copyright 2026 BPO Finance Operations",
    "resources": [
      "../automation-script/Yardi-Automation.ts",
      "../automation-scripts/Gmail-Agent.ts"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
